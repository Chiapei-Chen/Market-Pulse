# Data source mode:
# - twse_delayed: use delayed-real data from TWSE public APIs (recommended phase 1)
# - (empty): auto mode (use STOCK_TODAY_API_URL/STOCK_YESTERDAY_API_URL if provided, otherwise sample)
STOCK_DATA_SOURCE=twse_delayed

# Set to false only when local environment has certificate issues.
# Recommended for development troubleshooting only.
STOCK_HTTP_VERIFY_SSL=true

# Optional custom real data source endpoints returning JSON array of RankedStock.
# Used when both values are provided and STOCK_DATA_SOURCE is not twse_delayed.
STOCK_TODAY_API_URL=
STOCK_YESTERDAY_API_URL=
